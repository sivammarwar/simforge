import LandingPage from './components/landing/LandingPage';

import { getMemoryData, saveMemoryData, logMemoryEvent, formatTimestamp } from './services/memory';
import { detectContradiction } from './services/triz';
import { detectAllLookups } from './services/connectors';
import { runSolver, compileNetlist, runSolverInstant } from './services/solvers';
import { chatWithEngineeringBrain } from './services/llmClient';
import { applyNaturalLanguageUpdates, detectDomainFromPrompt, planChatWorkflow } from './services/chatOrchestrator';
import { runBrainWithTools, deriveRollingSummary, validateSVGOutput } from './services/brainOrchestrator';
import { generateSchematic } from './services/schematicEngine';
import { getPlots } from './services/plotEngine';
import {
  parseAndSemantifyQuestion,
  checkModelQuestionAlignment,
  checkPhysicalPlausibility,
  checkSolverOutputSanity,
  generateExplanation,
  configureAIKeys,
  getAIKeys
} from './services/aiLayers';
import {
  attachFlowMetadata,
  buildComparisonSummary,
  buildTrizDesignOptions,
  createFlowPlan,
  createIterationSuggestions,
  routeSolver,
  updateFlowStage
} from './services/simforgeFlow';

const DOMAIN_ORDER = ['Default', 'Physics', 'Circuits', 'Structural', 'Fluids', 'Semiconductors', 'Aerospace', 'Thermal', 'Control', 'Materials', 'Power'];

// Baseline Default Models
